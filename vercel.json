{
      "version": 2,
      "crons": [
              { "path": "/api/cron", "schedule": "0 15 * * *" },
              { "path": "/api/cron", "schedule": "0 18 * * *" },
              { "path": "/api/cron", "schedule": "0 21 * * *" },
              { "path": "/api/cron", "schedule": "0 0 * * *" },
              { "path": "/api/email-cron", "schedule": "0 16 * * *" },
              { "path": "/api/email-cron", "schedule": "0 19 * * *" },
              { "path": "/api/email-cron", "schedule": "0 22 * * *" },
              { "path": "/api/email-cron", "schedule": "0 1 * * *" },
                { "path": "/api/call-cron", "schedule": "0 16 * * *" },
                { "path": "/api/call-cron", "schedule": "0 19 * * *" },
                { "path": "/api/call-cron", "schedule": "0 22 * * *" }
      ],
      "redirects": [
              { "source": "/", "destination": "/dashboard", "permanent": false }
      ],
      "rewrites": [
              { "source": "/dashboard", "destination": "/api/dashboard" },
              { "source": "/logs", "destination": "/api/logs" },
              { "source": "/suppressed", "destination": "/api/suppressed" },
              { "source": "/unsubscribe", "destination": "/api/unsubscribe" },
              { "source": "/webhook", "destination": "/api/webhook" },
              { "source": "/sms-webhook", "destination": "/api/sms-webhook" },
                { "source": "/call-webhook", "destination": "/api/call-webhook" }
      ]
}
